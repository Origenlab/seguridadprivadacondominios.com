---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import Icon from '@/components/Icon.astro';
import CtaBanner from '@/components/CtaBanner.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('comunidades')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="Tipos de Comunidad que Protegemos | Seguridad para Condominios | CDMX y Edomex"
  description="Seguridad privada para cada tipo de comunidad: torres verticales, fraccionamientos, residenciales premium y cotos cerrados. Protección a la medida en CDMX y Edomex."
>
  <Breadcrumb items={[{ label: 'Comunidades' }]} />

  <Section
    eyebrow="Sectores atendidos"
    title="Tipos de comunidad que protegemos"
    subtitle="SEPRICO clasifica internamente a sus clientes en cuatro categorías operativas según las particularidades arquitectónicas, demográficas y de riesgo de cada formato residencial. Esta segmentación nos permite diseñar protocolos específicos en lugar de aplicar fórmulas genéricas."
    desc="Cada categoría tiene su propio mix recomendado de personal, tecnología y protocolos. La auditoría inicial define dónde encaja tu comunidad y qué configuración optimiza protección, presupuesto y experiencia del residente."
    align="center"
    as="h1"
  >
    <div class="grid gap-8 md:grid-cols-2">
      {items.map((c) => (
        <a href={`/comunidades/${c.slug}`} class="card-premium group flex flex-col">
          <div class="flex items-center justify-between">
            <span class="text-5xl">{c.data.emoji}</span>
            <Icon name="arrow" class="h-6 w-6 text-white/30" />
          </div>
          <h2 class="mt-6 text-2xl text-white">{c.data.title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-white/70">{c.data.description}</p>

          {c.data.challenges.length > 0 && (
            <ul class="mt-5 space-y-1.5 text-xs text-white/60">
              {c.data.challenges.slice(0, 3).map((ch) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-brand-500"></span>
                  <span>{ch}</span>
                </li>
              ))}
            </ul>
          )}
        </a>
      ))}
    </div>
  </Section>

  <CtaBanner
    title="¿No estás seguro qué tipo de propuesta necesitas?"
    subtitle="Visitamos tu comunidad y te recomendamos la mezcla óptima de personal y tecnología."
  />
</BaseLayout>
