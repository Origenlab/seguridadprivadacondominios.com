---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import Icon from '@/components/Icon.astro';
import CtaBanner from '@/components/CtaBanner.astro';
import ImageGallery, { type GalleryItem } from '@/components/ImageGallery.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('comunidades');
  return items.map((e) => ({ params: { slug: e.slug }, props: { entry: e } }));
}

interface Props { entry: CollectionEntry<'comunidades'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();

const allServicios = await getCollection('servicios');
const recommended = entry.data.recommended
  .map((slug) => allServicios.find((s) => s.slug === slug))
  .filter(Boolean) as CollectionEntry<'servicios'>[];

// Galería específica por tipo de comunidad (alt SEO contextualizado)
const COMMUNITY_GALLERY: Record<string, GalleryItem[]> = {
  'cotos-cerrados': [
    { src: '/images/banco/guardias-seguridad-rondines-condominio-03.avif', alt: `Rondines de seguridad privada en ${entry.data.title}`, caption: 'Rondines perimetrales' },
    { src: '/images/banco/familia-segura-condominio-residencial-04.avif', alt: `Familias seguras en ${entry.data.title}`, caption: 'Familias residentes' },
    { src: '/images/banco/patrullaje-interior-condominio-03.avif',         alt: `Patrullaje interior del coto cerrado`,                  caption: 'Patrullaje interior' },
    { src: '/images/banco/vigilancia-nocturna-condominios-02.avif',        alt: `Vigilancia nocturna en coto cerrado`,                   caption: 'Vigilancia nocturna' },
  ],
  'fraccionamientos': [
    { src: '/images/banco/familias-mexicanas-condominio-seguro-01.avif',   alt: `Familias seguras en fraccionamientos mexicanos`,        caption: 'Comunidad protegida' },
    { src: '/images/banco/guardias-seguridad-rondines-condominio-05.avif', alt: `Guardia haciendo rondines en fraccionamiento`,          caption: 'Rondines documentados' },
    { src: '/images/banco/familia-segura-condominio-residencial-05.avif',  alt: `Familia segura en fraccionamiento residencial`,         caption: 'Áreas comunes' },
    { src: '/images/banco/vigilancia-nocturna-condominios-03.avif',        alt: `Vigilancia nocturna en fraccionamiento`,                caption: 'Cobertura 24/7' },
  ],
  'residenciales-premium': [
    { src: '/images/banco/seguridad-privada-condominio-lujo-01.avif',      alt: `Seguridad privada en residenciales premium`,            caption: 'Estándar premium' },
    { src: '/images/banco/seguridad-privada-condominio-lujo-02.avif',      alt: `Guardia uniformado en residencial de lujo`,             caption: 'Guardias certificados' },
    { src: '/images/banco/caseta-seguridad-condominio-moderna-03.avif',    alt: `Caseta de seguridad moderna en residencial premium`,    caption: 'Caseta moderna' },
    { src: '/images/banco/familia-segura-condominio-residencial-06.avif',  alt: `Familia segura en residencial premium`,                 caption: 'Tranquilidad familiar' },
  ],
  'torres-verticales': [
    { src: '/images/banco/guardia-seguridad-atencion-residentes-02.avif',  alt: `Guardia atendiendo a residentes en torre vertical`,     caption: 'Atención a residentes' },
    { src: '/images/banco/patrullaje-interior-condominio-04.avif',         alt: `Patrullaje interior de torre vertical`,                 caption: 'Patrullaje en pisos' },
    { src: '/images/banco/guardia-seguridad-atencion-residentes-04.avif',  alt: `Recepción y atención en torre vertical`,                caption: 'Lobby y recepción' },
    { src: '/images/banco/seguridad-privada-estacionamiento-condominio-01.avif', alt: `Seguridad en estacionamiento de torre vertical`,   caption: 'Estacionamiento' },
  ],
};
const gallery = COMMUNITY_GALLERY[entry.slug] ?? [];
---

<BaseLayout title={entry.data.seoTitle ?? entry.data.title} description={entry.data.seoDescription ?? entry.data.description}>
  <Breadcrumb items={[
    { label: 'Comunidades', href: '/comunidades/' },
    { label: entry.data.title },
  ]} />

  <Section>
    <div class="mx-auto max-w-4xl">
      <div class="flex items-start gap-5">
        <span class="text-6xl">{entry.data.emoji}</span>
        <div>
          <span class="eyebrow">Comunidad atendida</span>
          <h1 class="mt-3 text-4xl font-bold leading-tight md:text-5xl">
            Seguridad Privada para {entry.data.title}
          </h1>
          <p class="mt-3 text-lg text-white/75">{entry.data.description}</p>
        </div>
      </div>

      {entry.data.challenges.length > 0 && (
        <div class="mt-10 rounded-2xl border border-white/5 bg-ink-900/40 p-6">
          <h2 class="text-lg text-brand-500">Retos típicos en este formato</h2>
          <ul class="mt-4 grid gap-2 text-white/85 md:grid-cols-2">
            {entry.data.challenges.map((ch) => (
              <li class="flex items-start gap-2">
                <Icon name="alert" class="mt-1 h-4 w-4 shrink-0 text-brand-500" />
                <span class="text-sm">{ch}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <article class="prose prose-invert prose-headings:prose-a:text-brand-500 mt-10 max-w-none">
        <Content />
      </article>
    </div>
  </Section>

  {gallery.length > 0 && (
    <ImageGallery
      eyebrow={`Operación SEPRICO en ${entry.data.title}`}
      title="Cobertura visual del esquema"
      subtitle={`Imágenes representativas de la operación de seguridad privada en ${entry.data.title.toLowerCase()}: rondines, atención a residentes y vigilancia perimetral. Personal certificado SETEC, supervisión 24/7.`}
      items={gallery}
      columns={2}
      bg="ink-800"
    />
  )}

  <Section>
    <div class="mx-auto max-w-4xl">

      {recommended.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl text-white">Servicios recomendados</h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {recommended.map((s) => (
              <a href={`/${s.slug}/`} class="card-premium group">
                <div class="flex items-center gap-4">
                  <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-500/15 text-brand-500">
                    <Icon name={s.data.icon} class="h-5 w-5" />
                  </span>
                  <div class="flex-1">
                    <h3 class="text-base">{s.data.title}</h3>
                    <p class="mt-1 text-xs text-white/65">{s.data.description}</p>
                  </div>
                  <Icon name="arrow" class="h-5 w-5 text-white/30 group-hover:text-brand-500" />
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </Section>

  <CtaBanner />
</BaseLayout>
