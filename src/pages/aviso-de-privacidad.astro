---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import { SITE } from '@/config/site';
---

<BaseLayout
  title="Aviso de Privacidad"
  description="Aviso de privacidad de Seguridad Privada Condominios conforme a la LFPDPPP."
>
  <Section
    eyebrow="Legal"
    title="Aviso de Privacidad"
  >
    <article class="prose prose-invert max-w-3xl">
      <p>
        <strong>{SITE.name}</strong>, con domicilio en {SITE.contact.address},
        es responsable del uso y protección de tus datos personales conforme a
        la Ley Federal de Protección de Datos Personales en Posesión de los
        Particulares (LFPDPPP).
      </p>

      <h2>Datos que recabamos</h2>
      <p>Nombre, teléfono, correo electrónico, ubicación del condominio y mensaje.</p>

      <h2>Finalidades</h2>
      <ul>
        <li>Atender solicitudes de cotización.</li>
        <li>Programar visitas técnicas y diagnóstico inicial.</li>
        <li>Enviar información comercial relacionada (puedes oponerte en cualquier momento).</li>
      </ul>

      <h2>Transferencias</h2>
      <p>
        No transferimos tus datos a terceros sin tu consentimiento expreso, salvo
        las excepciones previstas en el artículo 37 de la LFPDPPP.
      </p>

      <h2>Derechos ARCO</h2>
      <p>
        Puedes ejercer tus derechos de Acceso, Rectificación, Cancelación u
        Oposición enviando un correo a
        <a href={`mailto:${SITE.contact.email}`}>{SITE.contact.email}</a>.
      </p>

      <p class="text-sm text-white/60">Última actualización: 2026.</p>
    </article>
  </Section>
</BaseLayout>
