---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada" description="404" noindex>
  <section class="section">
    <div class="container-pro max-w-xl text-center">
      <p class="text-7xl text-brand-500">404</p>
      <h1 class="mt-4 text-3xl md:text-4xl">Página no encontrada</h1>
      <p class="mt-4 text-white/75">
        La página que buscas no existe o fue movida.
      </p>
      <a href="/" class="btn-brand mt-8 inline-flex">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>
