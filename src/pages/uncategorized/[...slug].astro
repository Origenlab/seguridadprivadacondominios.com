---
import BlogArticle from '@/components/BlogArticle.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    !data.draft && data.category === 'uncategorized'
  );
  return posts.map((p) => ({ params: { slug: p.id }, props: { entry: p } }));
}

interface Props { entry: CollectionEntry<'blog'>; }
const { entry } = Astro.props;
---

<BlogArticle
  entry={entry}
  category={{
    slug: 'uncategorized',
    label: 'General',
    headline: 'Blog SEPRICO',
    archiveHref: '/category/uncategorized/',
    articleSection: 'Blog de Seguridad Privada',
    icon: 'star',
  }}
/>
