---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import Icon from '@/components/Icon.astro';
import CtaBanner from '@/components/CtaBanner.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    !data.draft && data.category === 'uncategorized'
  );
  return posts.map((p) => ({ params: { slug: p.slug }, props: { entry: p } }));
}

interface Props { entry: CollectionEntry<'blog'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();

const fmt = (d: Date) => d.toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout title={entry.data.title} description={entry.data.description} type="article">
  <Breadcrumb items={[
    { label: 'Blog', href: '/blog/' },
    { label: 'Uncategorized', href: '/category/uncategorized/' },
    { label: entry.data.title },
  ]} />

  <Section>
    <article class="mx-auto max-w-3xl">
      <div class="flex items-center gap-3 text-[11px] uppercase tracking-widest2 text-brand-500">
        <Icon name="clock" class="h-3.5 w-3.5" />
        <span>{fmt(entry.data.pubDate)}</span>
        <span class="text-white/30">·</span>
        <span class="text-white/60">{entry.data.author}</span>
      </div>

      <h1 class="mt-5 text-4xl font-bold leading-tight md:text-5xl">{entry.data.title}</h1>
      <p class="mt-4 text-lg text-white/75">{entry.data.description}</p>

      <div class="hairline my-10"></div>

      <div class="prose prose-invert prose-headings:text-white prose-a:text-brand-500 max-w-none">
        <Content />
      </div>
    </article>
  </Section>

  <CtaBanner />
</BaseLayout>
