---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import QuickNavBottom from '@/components/QuickNavBottom.astro';
import Section from '@/components/Section.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import Icon from '@/components/Icon.astro';
import Process from '@/components/Process.astro';
import BadgeCard from '@/components/BadgeCard.astro';
import SubHubFaq from '@/components/SubHubFaq.astro';
import ChipsBar from '@/components/ChipsBar.astro';
import ClusterGrid from '@/components/ClusterGrid.astro';
import AboutSeprico from '@/components/AboutSeprico.astro';
import SchemaBreadcrumb from '@/components/SchemaBreadcrumb.astro';
import SchemaSpeakable from '@/components/SchemaSpeakable.astro';
import { SITE, SERVICIOS } from '@/config/site';
import { getEntry } from 'astro:content';

// ───── METADATA SEO ─────
const slug = 'tecnologia-y-monitoreo';
const canonicalPath = `/${slug}/`;
const canonicalUrl = new URL(canonicalPath, SITE.url).toString();
const seoTitle = 'Tecnología y Monitoreo para Condominios | CCTV y Alarmas | Centro 24/7';
const seoDescription =
  'Tecnología y monitoreo para condominios: CCTV HD/4K, control de acceso, alarmas y biometría en central 24/7. Infraestructura integrada en CDMX y Edomex.';
const keywords = [
  'tecnología de seguridad para condominios',
  'monitoreo electrónico residencial CDMX',
  'sistemas integrados de seguridad',
  'CCTV con control de acceso biométrico',
  'centro de monitoreo 24/7',
  'seguridad electrónica condominios Edomex',
  'integración CCTV alarmas e intercom',
];

// ───── 7 servicios del cluster ─────
const techSlugs = [
  'monitoreo-electronico',
  'sistemas-de-camaras-de-vigilancia',
  'control-de-acceso',
  'control-biometrico-de-acceso',
  'alarmas-de-seguridad',
  'intercomunicacion-avanzada',
  'sistemas-de-iluminacion-segura',
];

// ───── PROCESO general del cluster ─────
const clusterProcess = [
  {
    icon: 'phone' as const,
    title: 'Diagnóstico integrado',
    desc: 'Revisamos el ecosistema actual del condominio: cámaras existentes, alarmas, intercom y accesos. Identificamos silos operativos y oportunidades reales de integración.',
  },
  {
    icon: 'pin' as const,
    title: 'Levantamiento técnico sin costo',
    desc: 'Visita en sitio multidisciplinaria: red, eléctrico, perimetral y operativo. Diseño de arquitectura unificada con plano técnico documentado y validado.',
  },
  {
    icon: 'check' as const,
    title: 'Propuesta consolidada en 48 horas',
    desc: 'Cotización por servicio individual o paquete integral, plan de implementación por fases y SLAs contractuales agregados para todo el cluster.',
  },
  {
    icon: 'shield' as const,
    title: 'Implementación coordinada',
    desc: 'Despliegue por etapas con un solo equipo SEPRICO: cero conflictos entre proveedores, cero culpa cruzada cuando algo no integra entre subsistemas.',
  },
  {
    icon: 'star' as const,
    title: 'Operación unificada 24/7',
    desc: 'Centro de monitoreo opera todo el ecosistema con reporte mensual ejecutivo agregado y revisión trimestral con la mesa directiva del condominio.',
  },
];

// ───── BENEFICIOS del enfoque integrado ─────
const integratedBenefits = [
  {
    title: 'Un solo proveedor responsable',
    desc: 'Personal, tecnología y centro de monitoreo bajo una sola operación. No hay culpa cruzada entre proveedores cuando un evento no se atiende a tiempo.',
  },
  {
    title: 'Eventos sincronizados',
    desc: 'Una alarma activa la cámara correspondiente, el operador valida con video y el guardia recibe el aviso con contexto. Respuesta coordinada, no acciones aisladas.',
  },
  {
    title: 'Reporte ejecutivo unificado',
    desc: 'El comité recibe un solo informe mensual con KPIs agregados del ecosistema, no siete reportes desconectados por proveedor individual.',
  },
  {
    title: 'Cumplimiento legal blindado',
    desc: 'Permiso SSPC, LFPDPPP y NOM-001-SEDE cubiertos en cada implementación. Una sola política de privacidad y un solo expediente para todo el ecosistema.',
  },
  {
    title: 'Inversión protegida por fases',
    desc: 'El condominio puede arrancar con CCTV y monitoreo, y añadir acceso, alarmas e iluminación por etapas sin reemplazar la base ya instalada.',
  },
  {
    title: 'Mantenimiento coordinado',
    desc: 'Un solo cronograma de mantenimiento preventivo para todos los sistemas. Una visita técnica trimestral cubre el ecosistema completo, sin coordinación manual.',
  },
];

// ───── DIFERENCIADORES del cluster ─────
const clusterValueProps = [
  {
    icon: 'shield' as const,
    title: '25 años en seguridad residencial',
    desc: 'Desde el año 2000 implementando tecnología en condominios de CDMX y Edomex. Permiso SSPC vigente, ISO 9001:2015 y capacitación SETEC actualizada.',
  },
  {
    icon: 'cctv' as const,
    title: 'Centro de monitoreo propio',
    desc: 'No tercerizamos. Operadores SEPRICO certificados con SLA documentado, relevos cada 4 horas y respaldo eléctrico más conectividad dual blindada.',
  },
  {
    icon: 'check' as const,
    title: 'Marcas líderes con respaldo en México',
    desc: 'Hikvision, Dahua, ZKTeco, Suprema, Honeywell, Axis, Bosch y Philips. Refacciones disponibles localmente y soporte técnico documentado por contrato.',
  },
  {
    icon: 'clock' as const,
    title: 'SLAs contractuales medibles',
    desc: 'MTTD, MTTR, tasa de falsas alarmas filtradas y disponibilidad del sistema. Métricas escritas en contrato, no promesas verbales que se diluyen.',
  },
  {
    icon: 'phone' as const,
    title: 'Ejecutivo de cuenta dedicado',
    desc: 'Una persona con nombre y número directo atiende el ecosistema completo del condominio. Sin call centers ni interlocutores rotativos para escalaciones.',
  },
  {
    icon: 'star' as const,
    title: '94% de renovación al primer año',
    desc: 'Los comités que contratan el ecosistema integrado renuevan con SEPRICO. La integración operativa es más difícil de reemplazar que un proveedor más barato.',
  },
];

// ───── FAQ del cluster ─────
const clusterFaqs = [
  {
    q: '¿Puedo contratar los servicios por separado o tienen que ser todos juntos?',
    a: 'Por separado. Cada uno de los siete servicios se contrata individualmente. El valor del ecosistema crece cuando se integran porque la cadena de responsabilidad queda en un solo proveedor, pero no exigimos paquete completo para arrancar: empezamos donde el condominio más lo necesita.',
  },
  {
    q: '¿Qué diferencia hay entre contratar el cluster integrado vs proveedores separados?',
    a: 'La coordinación operativa real. Cuando cámaras, alarmas y acceso vienen de un solo proveedor, los eventos se procesan en sincronía y cada evento tiene un responsable claro. Con proveedores separados cada uno opera en silo y nadie es responsable cuando algo falla en la integración entre sistemas.',
  },
  {
    q: '¿Reutilizan el equipo existente del condominio?',
    a: 'Sí cuando es viable. Auditamos lo que ya está instalado: si la calidad de imagen, los codecs y los protocolos lo permiten, lo integramos a nuestra plataforma. Si está obsoleto, proponemos plan de migración por etapas sin tirar equipo prematuramente ni interrumpir la operación.',
  },
  {
    q: '¿Cuánto tiempo toma implementar el ecosistema completo?',
    a: 'Depende del alcance. Un condominio mediano arranca el centro de monitoreo en 2 a 3 semanas, integra accesos y alarmas en otras 4 semanas y completa iluminación e intercomunicación en 8 a 12 semanas totales. Implementamos por etapas para no interrumpir la operación.',
  },
  {
    q: '¿Quién opera el centro de monitoreo?',
    a: 'Personal SEPRICO certificado en nuestro centro propio de operaciones (NOC). No tercerizamos a centrales externas tipo Verisure ni ADT: la cadena de responsabilidad termina en SEPRICO sin intermediarios y el comité tiene un solo número para escalación.',
  },
  {
    q: '¿Qué reportes recibe el comité administrativo mes a mes?',
    a: 'Informe mensual ejecutivo con métricas agregadas del ecosistema: eventos detectados, MTTD, MTTR, falsas alarmas filtradas, disponibilidad de cada subsistema, consumo energético de iluminación y recomendaciones operativas. Revisión trimestral con la mesa directiva para ajustar protocolos.',
  },
];

// ───── Breadcrumb ─────
const breadcrumbItems = [
  { label: 'Servicios', href: '/servicios-de-seguridad-privada/' },
  { label: 'Tecnología y Monitoreo' },
];

// ───── QuickNav contextual ─────
const wa = `https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent('Hola SEPRICO, requiero información sobre tecnología y monitoreo')}`;
const quickNavBottomChips = [
  { label: 'Personal SETEC', sub: 'Pilar 1 — guardias y patrullaje', href: '/personal-de-seguridad-residencial/', icon: 'shield' as const },
  { label: 'Protocolos', sub: 'Pilar 3 — consultoría', href: '/protocolos-y-consultoria/', icon: 'check' as const },
  { label: 'Atención al Comité', sub: 'Pilar 4 — ejecutivo dedicado', href: '/atencion-al-comite-condominios/', icon: 'star' as const },
  { label: 'Catálogo completo', sub: '13 servicios SEPRICO', href: '/servicios-de-seguridad-privada/', icon: 'cctv' as const },
  { label: 'Contacto', sub: 'Cotización sin costo', href: '/empresa-de-seguridad-privada-para-condominios/', icon: 'mail' as const },
  { label: 'WhatsApp 24/7', sub: 'Respuesta en <15 min', href: wa, icon: 'phone' as const, external: true },
];

// ───── Schema: CollectionPage con Service[] por L3 ─────
const itemEntries = await Promise.all(
  techSlugs.map(async (s) => {
    const meta = SERVICIOS.find((sv) => sv.slug === s);
    const entry = await getEntry('servicios', s);
    return {
      slug: s,
      title: entry?.data.title ?? meta?.title ?? s,
      seoDesc: entry?.data.seoDescription ?? entry?.data.description ?? '',
      image: entry?.data.image ?? '/images/og/og-image.webp',
    };
  }),
);

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonicalUrl}#collection`,
  url: canonicalUrl,
  name: 'Tecnología y Monitoreo para Condominios y Residenciales',
  description: seoDescription,
  inLanguage: 'es-MX',
  isPartOf: { '@id': `${SITE.url}/#website` },
  about: {
    '@type': 'Thing',
    name: 'Tecnología de seguridad electrónica residencial en CDMX y Edomex',
  },
  mainEntity: {
    '@type': 'ItemList',
    name: 'Siete servicios de tecnología y monitoreo SEPRICO',
    numberOfItems: techSlugs.length,
    itemListElement: itemEntries.map((it, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Service',
        '@id': new URL(`/${it.slug}/`, SITE.url).toString(),
        url: new URL(`/${it.slug}/`, SITE.url).toString(),
        name: it.title,
        description: it.seoDesc,
        image: new URL(it.image, SITE.url).toString(),
        provider: { '@id': `${SITE.url}/#organization` },
        areaServed: SITE.coverage,
        serviceType: 'Seguridad electrónica residencial',
      },
    })),
  },
};

// ───── Schema: Speakable con selectores específicos del L2 ─────
const speakableSelectors = [
  'h1',
  '.section-title',
  '#servicios p',
  '#beneficios p',
  '#faq details summary',
];

// ───── ChipsBar top ─────
const topChips = techSlugs.map((s) => {
  const m = SERVICIOS.find((sv) => sv.slug === s);
  return { label: m?.title ?? s, href: `/${s}/`, icon: (m?.icon as any) ?? 'cctv' };
});
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  canonical={canonicalPath}
  type="website"
  keywords={keywords}
>
  <Fragment slot="schemas">
    <SchemaBreadcrumb items={breadcrumbItems} />
    <SchemaSpeakable url={canonicalUrl} selectors={speakableSelectors} />
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  </Fragment>

  <Breadcrumb items={breadcrumbItems} />

  {/* ══════════ 1. HERO ══════════ */}
  <Hero
    eyebrow="Pilar 2 — Tecnología y Monitoreo · CDMX y Edomex"
    label="SEPRICO · Ecosistema integral de"
    headline="Tecnología y Monitoreo"
    subheadline="para Condominios y Residenciales"
    body={`Siete sistemas profesionales que <strong class="text-white">operan como un solo ecosistema</strong>: CCTV, control de acceso biométrico, alarmas, intercomunicación IP e iluminación inteligente — todo enlazado al <strong class="text-white">centro de monitoreo 24/7</strong> de SEPRICO.`}
    asideP1={`Una cámara aislada no protege y un control de acceso sin monitoreo es una puerta sin vigilancia detrás. En <strong class="text-white">SEPRICO</strong> integramos siete sistemas en una arquitectura unificada que responde como un solo organismo operativo, no como piezas separadas que el comité tiene que sincronizar manualmente.`}
    asideP2={`Cada implementación parte de un <strong class="text-white">levantamiento técnico sin costo</strong>. Cotizamos cada servicio por separado o como paquete consolidado con plan de instalación por fases, SLAs medibles y operación coordinada desde nuestro NOC propio en CDMX.`}
    asideEyebrow="Sobre el pilar"
    isH1={true}
  />

  {/* ══════════ 2. QUICKNAV chips a los 7 L3 ══════════ */}
  <ChipsBar chips={topChips} ariaLabel="Servicios del cluster" />

  {/* ══════════ 3. LOS 7 SERVICIOS ══════════ */}
  <Section
    id="servicios"
    eyebrow="Servicios del ecosistema"
    title="Los siete sistemas que protegen tu condominio"
    subtitle="Cada servicio se contrata por separado o integrado al cluster. La operación coordinada y el centro de monitoreo 24/7 son los mismos en ambos casos."
    desc="Cuatro servicios cubren protección activa (cámaras, alarmas, acceso, biométrico), uno opera el centro de monitoreo y dos refuerzan la operación (intercomunicación e iluminación segura)."
  >
    <ClusterGrid slugs={techSlugs} cols={4} />
  </Section>

  {/* ══════════ 4. INTEGRACIÓN CRUZADA — 4 EJES ══════════ */}
  <Section
    eyebrow="Cómo se conectan"
    title="Integración cruzada entre los siete sistemas"
    subtitle="Un evento en un subsistema dispara automáticamente la respuesta coordinada del resto. Esto es lo que hace que el ecosistema valga más que la suma de sus partes."
    desc="Estos son los cuatro ejes principales de integración que el comité puede operacionalizar desde el primer mes."
    bg="darker"
  >
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      <BadgeCard
        icon="cctv"
        title="Detección + verificación"
        desc="Alarmas y sensores activan grabación dedicada en la cámara correspondiente. El operador valida con video antes de movilizar al guardia o autoridades. Cero despachos en vano."
      />
      <BadgeCard
        icon="access"
        title="Identidad + acceso"
        desc="Control biométrico, tarjetas RFID, registro de visitantes e intercomunicación operan bajo un solo panel. Cada lectura genera bitácora con video sincronizado del momento exacto."
      />
      <BadgeCard
        icon="shield"
        title="Iluminación + CCTV"
        desc="La iluminación inteligente se calibra para que las cámaras Color Vu y ColorView devuelvan imagen útil 24/7. La luz correcta multiplica el rendimiento del sistema CCTV existente."
      />
      <BadgeCard
        icon="check"
        title="Cumplimiento + auditabilidad"
        desc="Una sola política LFPDPPP, una sola bitácora cifrada y un solo expediente legal cubren los siete subsistemas. Auditoría del comité en minutos, no en días."
      />
    </div>
  </Section>

  {/* ══════════ 5. BENEFICIOS DEL ENFOQUE INTEGRADO ══════════ */}
  <Section
    id="beneficios"
    eyebrow="Ventajas del ecosistema"
    title="Por qué el cluster integrado supera a proveedores separados"
    subtitle="El valor no está en cada equipo aislado: está en la coordinación operativa entre los siete sistemas bajo un solo proveedor responsable."
    desc="Los condominios que migran de múltiples proveedores a este modelo reducen costos administrativos y mejoran los tiempos de respuesta documentados en bitácora."
  >
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {integratedBenefits.map((b, i) => (
        <BadgeCard title={b.title} desc={b.desc} number={String(i + 1).padStart(2, '0')} />
      ))}
    </div>
  </Section>

  {/* ══════════ 6. PROCESO DE IMPLEMENTACIÓN ══════════ */}
  <Section
    id="proceso"
    eyebrow="Cómo lo implementamos"
    title="Del diagnóstico a la operación unificada"
    subtitle="Cinco etapas documentadas que el comité supervisa en tiempo real. Cero contratos paralelos, cero coordinación manual entre proveedores."
    desc="Cada etapa con entregables claros y validación del comité antes de avanzar a la siguiente."
    bg="darker"
  >
    <Process items={clusterProcess} />

    <div class="mt-12 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a href="/empresa-de-seguridad-privada-para-condominios/" class="btn-brand inline-flex items-center gap-2">
        <Icon name="phone" class="h-4 w-4" />
        Iniciar diagnóstico gratuito
      </a>
      <a href={wa} target="_blank" rel="noopener noreferrer" class="btn-ghost inline-flex items-center gap-2">
        <Icon name="check" class="h-4 w-4" />
        WhatsApp 24/7
      </a>
    </div>
  </Section>

  {/* ══════════ 7. DIFERENCIADORES SEPRICO ══════════ */}
  <Section
    id="diferenciadores"
    eyebrow="Por qué SEPRICO"
    title="Qué distingue al cluster Tecnología y Monitoreo de SEPRICO"
    subtitle="No competimos por hardware ni por precio: competimos por integración operativa, cumplimiento legal documentado y centro de monitoreo propio."
    desc="Cada diferenciador es una decisión operativa concreta, verificable contra el contrato y los reportes mensuales que recibe el comité administrativo."
  >
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {clusterValueProps.map((v) => (
        <BadgeCard title={v.title} desc={v.desc} icon={v.icon} />
      ))}
    </div>
  </Section>

  {/* ══════════ 8. FAQ del cluster ══════════ */}
  <Section
    id="faq"
    eyebrow="Preguntas frecuentes"
    title="Dudas comunes sobre el ecosistema tecnológico"
    subtitle="Las preguntas que los comités administrativos hacen con más frecuencia al evaluar el cluster integrado frente al modelo de proveedores separados."
    desc="Si tu duda no aparece aquí, escríbenos por WhatsApp y un asesor especializado te responde en menos de 15 minutos."
    bg="darker"
  >
    <SubHubFaq items={clusterFaqs} contextMessage="Hola SEPRICO, requiero información sobre tecnología y monitoreo" />
  </Section>

  {/* ══════════ 9. ACERCA DE SEPRICO ══════════ */}
  <AboutSeprico serviceContext="el ecosistema de tecnología y monitoreo" />

  {/* ══════════ 10. QUICKNAV BOTTOM ══════════ */}
  <QuickNavBottom chips={quickNavBottomChips} />
</BaseLayout>
