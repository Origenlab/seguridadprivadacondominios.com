---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Section from '@/components/Section.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import Icon from '@/components/Icon.astro';
import CtaBanner from '@/components/CtaBanner.astro';
import { SITE } from '@/config/site';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    !data.draft && data.category === 'seguridad-privada'
  );
  return posts.map((p) => ({ params: { slug: p.slug }, props: { entry: p } }));
}

interface Props { entry: CollectionEntry<'blog'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();

const fmt = (d: Date) => d.toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });

// Posts relacionados (mismos tags, excluyendo el actual)
const all = await getCollection('blog', ({ data }) => !data.draft);
const related = all
  .filter((p) => p.slug !== entry.slug && p.data.tags.some((t) => entry.data.tags.includes(t)))
  .slice(0, 4);

const wa = `https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent(SITE.contact.whatsappMessage)}`;
---

<BaseLayout title={entry.data.title} description={entry.data.description} type="article">
  <Breadcrumb items={[
    { label: 'Blog', href: '/blog/' },
    { label: 'Seguridad privada', href: '/category/seguridad-privada/' },
    { label: entry.data.title },
  ]} />

  <Section>
    <div class="grid gap-10 lg:grid-cols-12">
      <!-- CONTENIDO PRINCIPAL -->
      <article class="lg:col-span-8">
        <div class="flex flex-wrap items-center gap-3 text-[11px] uppercase tracking-widest2 text-brand-500">
          <span class="inline-flex items-center gap-1.5">
            <Icon name="clock" class="h-3.5 w-3.5" />
            {fmt(entry.data.pubDate)}
          </span>
          <span class="text-white/30">·</span>
          <span class="text-white/60">{entry.data.author}</span>
          <span class="text-white/30">·</span>
          <a href="/category/seguridad-privada/" class="text-brand-500 hover:text-brand-400">Seguridad privada</a>
        </div>

        <h1 class="mt-5 text-3xl font-bold leading-tight text-white md:text-5xl">{entry.data.title}</h1>
        <p class="mt-4 text-lg text-white/75">{entry.data.description}</p>

        <div class="hairline my-8"></div>

        <div class="prose prose-invert prose-headings:text-white prose-headings:font-bold prose-a:text-brand-500 hover:prose-a:text-brand-400 prose-strong:text-white max-w-none">
          <Content />
        </div>

        <!-- Tags -->
        <div class="mt-10 flex flex-wrap gap-2 border-t border-white/5 pt-6">
          {entry.data.tags.map((t) => (
            <a href="/category/seguridad-privada/" class="rounded-md border border-white/10 bg-ink-900 px-3 py-1 text-xs uppercase tracking-widest2 text-white/70 hover:border-brand-500/40 hover:text-brand-500">
              #{t}
            </a>
          ))}
        </div>
      </article>

      <!-- SIDEBAR -->
      <aside class="lg:col-span-4 space-y-6">
        <!-- Sobre SEPRICO -->
        <div class="card">
          <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-widest2 text-brand-500">
            <span class="h-1 w-1 rounded-full bg-brand-500"></span>
            Sobre SEPRICO
          </span>
          <h3 class="mt-3 text-lg font-bold text-white">
            <a href="/" class="hover:text-brand-500">Seguridad Privada para Condominios</a>
          </h3>
          <p class="mt-2 text-sm text-white/70">
            Empresa especializada desde el año 2000 en seguridad privada para
            condominios, fraccionamientos y residenciales en CDMX y Estado de
            México.
          </p>
          <a href="/" class="btn-brand mt-5 w-full text-xs">
            Conocer SEPRICO
            <Icon name="arrow" class="h-3.5 w-3.5" />
          </a>
        </div>

        <!-- Cotización rápida -->
        <div class="card bg-brand-500/10 border-brand-500/30">
          <span class="grid h-10 w-10 place-items-center rounded-md bg-brand-500 text-white">
            <Icon name="phone" class="h-5 w-5" />
          </span>
          <h3 class="mt-4 text-lg font-bold text-white">¿Cotizas seguridad para tu condominio?</h3>
          <p class="mt-2 text-sm text-white/75">
            Auditoría inicial sin costo. Respuesta en menos de 24 horas hábiles.
          </p>
          <a href={wa} target="_blank" rel="noopener noreferrer" class="btn bg-white text-brand-600 hover:bg-white/90 mt-4 w-full text-xs">
            WhatsApp directo
          </a>
          <a href="/empresa-de-seguridad-privada-para-condominios/" class="btn-ghost mt-2 w-full text-xs">
            Formulario de contacto
          </a>
        </div>

        <!-- Servicios destacados -->
        <div class="card">
          <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-widest2 text-brand-500">
            <span class="h-1 w-1 rounded-full bg-brand-500"></span>
            Servicios SEPRICO
          </span>
          <h3 class="mt-3 text-lg font-bold text-white">Catálogo principal</h3>
          <ul class="mt-4 space-y-2.5 text-sm">
            <li><a href="/personal-de-seguridad/" class="flex items-center justify-between text-white/75 hover:text-brand-500"><span>Personal de seguridad</span><Icon name="arrow" class="h-3 w-3" /></a></li>
            <li><a href="/monitoreo-electronico/" class="flex items-center justify-between text-white/75 hover:text-brand-500"><span>Monitoreo electrónico</span><Icon name="arrow" class="h-3 w-3" /></a></li>
            <li><a href="/control-de-acceso/" class="flex items-center justify-between text-white/75 hover:text-brand-500"><span>Control de acceso</span><Icon name="arrow" class="h-3 w-3" /></a></li>
            <li><a href="/vigilancia-y-patrullaje/" class="flex items-center justify-between text-white/75 hover:text-brand-500"><span>Vigilancia y patrullaje</span><Icon name="arrow" class="h-3 w-3" /></a></li>
            <li><a href="/alarmas-de-seguridad/" class="flex items-center justify-between text-white/75 hover:text-brand-500"><span>Alarmas de seguridad</span><Icon name="arrow" class="h-3 w-3" /></a></li>
            <li><a href="/consultoria-en-seguridad/" class="flex items-center justify-between text-white/75 hover:text-brand-500"><span>Consultoría</span><Icon name="arrow" class="h-3 w-3" /></a></li>
          </ul>
          <a href="/servicios-de-seguridad-privada/" class="mt-4 inline-flex items-center gap-1.5 text-xs font-semibold text-brand-500 hover:text-brand-400">
            Ver todos los servicios
            <Icon name="arrow" class="h-3 w-3" />
          </a>
        </div>

        <!-- Cobertura -->
        <div class="card">
          <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-widest2 text-brand-500">
            <span class="h-1 w-1 rounded-full bg-brand-500"></span>
            Cobertura
          </span>
          <h3 class="mt-3 text-lg font-bold text-white">CDMX y Edomex</h3>
          <p class="mt-2 text-sm text-white/70">
            Operamos en toda la Zona Metropolitana del Valle de México con
            respuesta cercana y supervisión activa.
          </p>
          <a href="/zonas/" class="mt-4 inline-flex items-center gap-1.5 text-xs font-semibold text-brand-500 hover:text-brand-400">
            Ver zonas de cobertura
            <Icon name="arrow" class="h-3 w-3" />
          </a>
        </div>

        <!-- Posts relacionados -->
        {related.length > 0 && (
          <div class="card">
            <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-widest2 text-brand-500">
              <span class="h-1 w-1 rounded-full bg-brand-500"></span>
              Relacionados
            </span>
            <h3 class="mt-3 text-lg font-bold text-white">Sigue leyendo</h3>
            <ul class="mt-4 space-y-4">
              {related.map((p) => (
                <li>
                  <a href={`/${p.data.category}/${p.slug}/`} class="group block">
                    <p class="text-[10px] uppercase tracking-widest2 text-brand-500">{fmt(p.data.pubDate)}</p>
                    <p class="mt-1 text-sm font-semibold text-white group-hover:text-brand-500">{p.data.title}</p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </Section>

  <CtaBanner />
</BaseLayout>
