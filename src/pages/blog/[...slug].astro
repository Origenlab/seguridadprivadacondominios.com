---
// Redirect: /blog/{slug}/ → /{category}/{slug}/ (URL canónica en producción)
// Despacha por categoría real del frontmatter (sin esto, todos iban a
// /seguridad-privada/{slug}/ y 70 de 117 posts caían en 404).
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { slug: p.slug, category: p.data.category },
  }));
}

const { slug, category } = Astro.props;
const target = `/${category}/${slug}/`;
---
<!doctype html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8" />
  <title>Redirigiendo…</title>
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <link rel="canonical" href={target} />
  <meta name="robots" content="noindex" />
</head>
<body>
  <p>Redirigiendo a <a href={target}>{target}</a>…</p>
  <script is:inline define:vars={{ target }}>window.location.replace(target);</script>
</body>
</html>
