---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import QuickNav from '@/components/QuickNav.astro';
import QuickNavBottom from '@/components/QuickNavBottom.astro';
import Section from '@/components/Section.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import Icon from '@/components/Icon.astro';
import BlogSidebar from '@/components/BlogSidebar.astro';
import { SITE } from '@/config/site';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const PER_PAGE = 9;
const page1    = allPosts.slice(0, PER_PAGE);
const total    = allPosts.length;
const totalPages = Math.ceil(total / PER_PAGE);

const CAT_META: Record<string, { label: string; icon: string }> = {
  'seguridad-privada':        { label: 'Seguridad Privada',        icon: 'shield' },
  'tecnologia-y-monitoreo':   { label: 'Tecnología y Monitoreo',   icon: 'cctv'   },
  'personal-de-seguridad':    { label: 'Personal de Seguridad',    icon: 'patrol' },
  'protocolos-y-consultoria': { label: 'Protocolos y Consultoría', icon: 'check'  },
  'atencion-al-comite':       { label: 'Atención al Comité',       icon: 'phone'  },
  'vigilancia':               { label: 'Vigilancia',               icon: 'patrol' },
  'uncategorized':            { label: 'General',                  icon: 'star'   },
};

const [featured, ...gridPosts] = page1;
const featMeta = CAT_META[featured.data.category];
---

<BaseLayout
  title="Blog de Seguridad Privada para Condominios | SEPRICO"
  description="Artículos técnicos, guías operativas y análisis de seguridad residencial para comités administrativos, presidentes vecinales y administradores de condominios en CDMX y Edomex."
>
  <Breadcrumb items={[{ label: 'Blog' }]} />

  <!-- ══════════════════════════════════════════════════════════════
       1. HERO
  ══════════════════════════════════════════════════════════════ -->
  <Hero
    eyebrow="Centro de recursos · CDMX y Edomex"
    label="SEPRICO · Blog de"
    headline="Seguridad Privada"
    subheadline="para Comités Administrativos"
    body={`<strong class="text-white">${total} artículos</strong> sobre seguridad residencial: selección de proveedor, protocolos de acceso, integración tecnológica, gestión de personal y gobernanza para comités vecinales — todo con criterio operativo, no comercial.`}
    asideP1={`Cada publicación nace de un caso real atendido por <strong class="text-white">SEPRICO</strong> en condominios de CDMX y Estado de México. No es contenido genérico de marketing: es documentación práctica pensada para presidentes de comité, administradores profesionales y líderes vecinales que quieren tomar mejores decisiones.`}
    asideP2={`Encontrarás guías técnicas, análisis de errores frecuentes, comparativas de tecnología y marcos de evaluación para proveedores de seguridad. Todo publicado de forma abierta, sin formularios de suscripción.`}
    isH1={true}
  />
  <QuickNav />

  <!-- ══════════════════════════════════════════════════════════════
       2. ARTÍCULOS + SIDEBAR
  ══════════════════════════════════════════════════════════════ -->
  <Section
    eyebrow="Publicaciones recientes"
    title="Últimos artículos del blog"
    subtitle="Del más reciente al más antiguo. Usa las categorías del panel lateral para filtrar por tema o navega directamente a los servicios relacionados."
    bg="darker"
  >
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-12">

      <!-- ══ COLUMNA PRINCIPAL ══ -->
      <main class="lg:col-span-8 min-w-0">

        <!-- ── Artículo destacado ── -->
        {featured && (
          <a
            href={`/${featured.data.category}/${featured.slug}/`}
            class="group mb-10 grid overflow-hidden rounded-2xl border border-white/10 bg-ink-800 md:grid-cols-5 hover:border-brand-500/40"
          >
            {/* Visual lateral */}
            <div class="relative aspect-[16/10] overflow-hidden bg-gradient-to-br from-brand-500/90 via-brand-600 to-ink-900 md:col-span-2 md:aspect-auto">
              {featured.data.image ? (
                <img
                  src={featured.data.image}
                  alt={featured.data.imageAlt ?? featured.data.title}
                  loading="eager"
                  decoding="async"
                  width="1600"
                  height="900"
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                />
              ) : (
                <>
                  <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(255,255,255,0.18),transparent_55%)]"></div>
                  <div class="absolute inset-0 grid place-items-center">
                    <Icon name={(featMeta?.icon ?? 'shield') as any} class="h-24 w-24 text-white/30" />
                  </div>
                </>
              )}
              <span class="absolute left-5 top-5 z-10 inline-flex items-center gap-1.5 rounded-full bg-black/55 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest2 text-white backdrop-blur-sm">
                <Icon name="star" class="h-3 w-3" />
                Destacado
              </span>
            </div>

            {/* Body */}
            <div class="flex flex-col justify-between p-6 md:col-span-3 md:p-8">
              <div>
                <div class="flex flex-wrap items-center gap-3">
                  {featMeta && (
                    <span class="rounded-md border border-brand-500/30 bg-brand-500/10 px-2.5 py-1 text-[10px] font-bold uppercase tracking-widest2 text-brand-300">
                      {featMeta.label}
                    </span>
                  )}
                </div>
                <h2 class="mt-4 text-2xl font-bold leading-tight text-white group-hover:text-brand-400 md:text-3xl">
                  {featured.data.title}
                </h2>
                <p class="mt-4 text-sm leading-relaxed text-white/70 line-clamp-3 md:text-base">
                  {featured.data.description}
                </p>
              </div>
              <span class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-brand-500 group-hover:text-brand-400">
                Leer artículo completo
                <Icon name="arrow" class="h-4 w-4" />
              </span>
            </div>
          </a>
        )}

        <!-- ── Grid de artículos ── -->
        <div class="grid gap-6 sm:grid-cols-2">
          {gridPosts.map((p) => {
            const meta = CAT_META[p.data.category];
            return (
              <a
                href={`/${p.data.category}/${p.slug}/`}
                class="group flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-ink-800 hover:border-brand-500/40"
              >
                {/* Visual header */}
                <div class="relative aspect-[16/8] overflow-hidden bg-gradient-to-br from-ink-700 via-ink-800 to-ink-900">
                  {p.data.image ? (
                    <img
                      src={p.data.image}
                      alt={p.data.imageAlt ?? p.data.title}
                      loading="lazy"
                      decoding="async"
                      width="800"
                      height="400"
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                    />
                  ) : (
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,rgba(244,63,63,0.25),transparent_55%)]"></div>
                  )}
                  <span class="absolute left-4 top-4 z-10 grid h-10 w-10 place-items-center rounded-lg bg-brand-500 text-white shadow-md shadow-brand-500/30">
                    <Icon name={(meta?.icon ?? 'shield') as any} class="h-5 w-5" />
                  </span>
                  {meta && (
                    <span class="absolute right-4 top-4 z-10 rounded-md border border-white/15 bg-black/55 px-2.5 py-1 text-[10px] font-bold uppercase tracking-widest2 text-white backdrop-blur-sm">
                      {meta.label}
                    </span>
                  )}
                </div>

                {/* Body */}
                <div class="flex flex-1 flex-col p-6">
                  <h2 class="text-base font-bold leading-snug text-white line-clamp-3 group-hover:text-brand-400">
                    {p.data.title}
                  </h2>
                  <p class="mt-3 flex-1 text-sm leading-relaxed text-white/65 line-clamp-3">
                    {p.data.description}
                  </p>
                  <span class="mt-5 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest2 text-brand-500 group-hover:text-brand-400">
                    Leer artículo
                    <Icon name="arrow" class="h-3.5 w-3.5" />
                  </span>
                </div>
              </a>
            );
          })}
        </div>

        <!-- ── Paginación ── -->
        {totalPages > 1 && (
          <nav class="mt-12 flex flex-col items-center justify-between gap-5 border-t border-white/10 pt-8 sm:flex-row">
            <span class="text-xs text-white/50">
              Página <strong class="text-white">1</strong> de {totalPages} · {total} artículos en total
            </span>
            <div class="flex items-center gap-1.5">
              <span class="grid h-10 w-10 place-items-center rounded-lg bg-brand-500 text-sm font-bold text-white shadow-md shadow-brand-500/30">
                1
              </span>
              {Array.from({ length: Math.min(totalPages - 1, 4) }, (_, i) => i + 2).map((n) => (
                <a
                  href={`/blog/page/${n}/`}
                  class="grid h-10 w-10 place-items-center rounded-lg border border-white/10 bg-ink-800 text-sm font-semibold text-white/70 hover:border-brand-500/50 hover:text-white"
                >
                  {n}
                </a>
              ))}
              {totalPages > 5 && (
                <span class="px-1 text-white/30">…</span>
              )}
              <a
                href="/blog/page/2/"
                class="grid h-10 w-10 place-items-center rounded-lg border border-white/10 bg-ink-800 text-base text-white/70 hover:border-brand-500/50 hover:text-white"
                aria-label="Página siguiente"
              >
                ›
              </a>
            </div>
          </nav>
        )}

      </main>

      <!-- ══ SIDEBAR ══ -->
      <div class="lg:col-span-4">
        <BlogSidebar />
      </div>

    </div>
  </Section>

  <!-- ══════════════════════════════════════════════════════════════
       3. QUICK NAV BOTTOM
  ══════════════════════════════════════════════════════════════ -->
  <QuickNavBottom chips={[
    { label: 'Servicios',       sub: 'Catálogo completo SEPRICO',              href: '/servicios-de-seguridad-privada/',  icon: 'shield'  },
    { label: 'Nosotros',        sub: 'Empresa desde el año 2000',              href: '/nosotros/',                        icon: 'star'    },
    { label: 'Vigilancia 24/7', sub: 'Personal certificado SETEC',             href: '/vigilancia-y-patrullaje/',         icon: 'patrol'  },
    { label: 'Monitoreo CCTV',  sub: 'Centro de monitoreo propio',             href: '/monitoreo-electronico/',           icon: 'cctv'    },
    { label: 'Consultoría',     sub: 'Auditorías y protocolos',                href: '/consultoria-en-seguridad/',        icon: 'check'   },
    { label: 'WhatsApp 24/7',   sub: 'Respuesta en menos de 15 min',          href: `https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent(SITE.contact.whatsappMessage)}`, icon: 'phone', external: true },
  ]} />

</BaseLayout>
