---
import BlogArticle from '@/components/BlogArticle.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    !data.draft && data.category === 'atencion-al-comite'
  );
  return posts.map((p) => ({ params: { slug: p.id }, props: { entry: p } }));
}

interface Props { entry: CollectionEntry<'blog'>; }
const { entry } = Astro.props;
---

<BlogArticle
  entry={entry}
  category={{
    slug: 'atencion-al-comite',
    label: 'Atención al Comité',
    headline: 'Atención al Comité',
    archiveHref: '/category/atencion-al-comite/',
    articleSection: 'Atención al Comité de Condominios',
    icon: 'phone',
  }}
/>
