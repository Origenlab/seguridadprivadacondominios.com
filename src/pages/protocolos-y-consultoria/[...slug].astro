---
import BlogArticle from '@/components/BlogArticle.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    !data.draft && data.category === 'protocolos-y-consultoria'
  );
  return posts.map((p) => ({ params: { slug: p.slug }, props: { entry: p } }));
}

interface Props { entry: CollectionEntry<'blog'>; }
const { entry } = Astro.props;
---

<BlogArticle
  entry={entry}
  category={{
    slug: 'protocolos-y-consultoria',
    label: 'Protocolos y Consultoría',
    headline: 'Protocolos y Consultoría',
    archiveHref: '/category/protocolos-y-consultoria/',
    articleSection: 'Protocolos y Consultoría de Seguridad',
    icon: 'check',
  }}
/>
