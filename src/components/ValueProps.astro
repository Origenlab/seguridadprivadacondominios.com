---
import Icon from '@/components/Icon.astro';

const items = [
  {
    icon: 'shield',
    title: 'Personal certificado',
    desc: 'Selección rigurosa, exámenes psicométricos, capacitación SETEC y evaluación continua para cada elemento asignado a tu condominio.',
    href: '/personal-de-seguridad/',
    cta: 'Conocer al equipo',
    image: '/images/rrhh/personal-de-seguridad.avif',
  },
  {
    icon: 'patrol',
    title: 'Supervisión activa',
    desc: 'Supervisores rotativos auditan cada turno y respaldan con bitácora digital, reportes mensuales y visitas no anunciadas.',
    href: '/vigilancia-y-patrullaje/',
    cta: 'Ver supervisión',
    image: '/images/servicios/vigilancia-y-patrullaje.avif',
  },
  {
    icon: 'cctv',
    title: 'Tecnología integrada',
    desc: 'CCTV, control de acceso biométrico, alarmas y rondines integrados en una sola plataforma operativa para el comité.',
    href: '/tecnologia-y-monitoreo/',
    cta: 'Ver tecnología',
    image: '/images/servicios/monitoreo-electronico.avif',
  },
  {
    icon: 'check',
    title: 'Trato premium',
    desc: 'Imagen impecable, protocolo de cortesía, discreción profesional y trato VIP con cada residente las 24 horas del día.',
    href: '/nosotros/',
    cta: 'Conocer más',
    image: '/images/general/seguridad-residenciales.avif',
  },
];
---

<div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
  {items.map((v) => (
    <a href={v.href} class="service-card group flex flex-col">
      <div class="service-card-image">
        <img
          src={v.image}
          alt={v.title}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/60 to-ink-950/10"></div>
        <span class="absolute top-3 left-3 grid h-10 w-10 place-items-center rounded-md bg-brand-500/90 text-white backdrop-blur-sm">
          <Icon name={v.icon as any} class="h-5 w-5" />
        </span>
        <div class="absolute bottom-0 left-0 right-0 p-5">
          <h3 class="text-lg font-bold leading-tight text-white">{v.title}</h3>
        </div>
      </div>

      <div class="service-card-body">
        <p class="flex-1 text-sm leading-relaxed text-white/70">{v.desc}</p>
        <span class="mt-5 inline-flex items-center gap-2 text-xs font-semibold text-brand-500 group-hover:text-brand-400">
          {v.cta}
          <Icon name="arrow" class="h-3.5 w-3.5" />
        </span>
      </div>
    </a>
  ))}
</div>
