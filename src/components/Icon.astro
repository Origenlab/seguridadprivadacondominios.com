---
interface Props {
  name:
    | 'shield'
    | 'cctv'
    | 'patrol'
    | 'access'
    | 'alert'
    | 'check'
    | 'phone'
    | 'mail'
    | 'pin'
    | 'clock'
    | 'star'
    | 'arrow';
  class?: string;
}
const { name, class: className = 'h-6 w-6' } = Astro.props;
---

{name === 'shield' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class={className}>
    <path d="M12 3 4 6v6c0 4.6 3.4 8.8 8 10 4.6-1.2 8-5.4 8-10V6l-8-3Z" />
    <path d="m9 12 2 2 4-4" />
  </svg>
)}
{name === 'cctv' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class={className}>
    <path d="M2 6h13a3 3 0 0 1 3 3v3l4-2v8l-4-2v3H4a2 2 0 0 1-2-2V6Z" />
    <circle cx="8" cy="11" r="1.5" />
  </svg>
)}
{name === 'patrol' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class={className}>
    <circle cx="12" cy="12" r="9" />
    <path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1" />
  </svg>
)}
{name === 'access' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class={className}>
    <rect x="3" y="11" width="18" height="10" rx="2" />
    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
    <circle cx="12" cy="16" r="1.2" fill="currentColor" />
  </svg>
)}
{name === 'alert' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class={className}>
    <path d="M12 2 2 21h20L12 2Z" />
    <path d="M12 10v5M12 18.5v.5" />
  </svg>
)}
{name === 'check' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class={className}>
    <path d="m5 12 5 5L20 7" />
  </svg>
)}
{name === 'phone' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class={className}>
    <path d="M22 16.9v3a2 2 0 0 1-2.2 2A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7l.5 2.4a2 2 0 0 1-.6 1.9L8 9a16 16 0 0 0 7 7l1-1a2 2 0 0 1 1.9-.6l2.4.5a2 2 0 0 1 1.7 2Z" />
  </svg>
)}
{name === 'mail' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class={className}>
    <rect x="3" y="5" width="18" height="14" rx="2" />
    <path d="m3 7 9 6 9-6" />
  </svg>
)}
{name === 'pin' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class={className}>
    <path d="M12 22s7-6.5 7-12a7 7 0 1 0-14 0c0 5.5 7 12 7 12Z" />
    <circle cx="12" cy="10" r="2.5" />
  </svg>
)}
{name === 'clock' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class={className}>
    <circle cx="12" cy="12" r="9" />
    <path d="M12 7v5l3 2" />
  </svg>
)}
{name === 'star' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class={className}>
    <path d="M12 2.5 14.6 9l6.9.6-5.2 4.6 1.6 6.8L12 17.6 6.1 21l1.6-6.8L2.5 9.6 9.4 9 12 2.5Z" />
  </svg>
)}
{name === 'arrow' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class={className}>
    <path d="M5 12h14M13 5l7 7-7 7" />
  </svg>
)}
