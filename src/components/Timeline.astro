---
interface Milestone {
  year: string;
  title: string;
  desc: string;
}
interface Props { items: Milestone[]; }
const { items } = Astro.props;
---

<ol class="relative space-y-10 border-l border-white/10 pl-8 md:pl-10">
  {items.map((m, i) => (
    <li class="relative">
      <!-- Punto en la línea -->
      <span class="absolute -left-[35px] md:-left-[43px] top-1 grid h-7 w-7 place-items-center rounded-full bg-brand-500 text-[10px] font-bold text-white ring-4 ring-ink-950">
        {String(i + 1).padStart(2, '0')}
      </span>
      <div class="flex flex-wrap items-baseline gap-3">
        <span class="text-xs font-semibold uppercase tracking-widest2 text-brand-500">
          {m.year}
        </span>
      </div>
      <h3 class="mt-1 text-xl font-bold text-white md:text-2xl">{m.title}</h3>
      <p class="mt-2 text-sm leading-relaxed text-white/70 md:text-base">{m.desc}</p>
    </li>
  ))}
</ol>
