---
const sectors = [
  { name: 'Condominios verticales', icon: '🏢' },
  { name: 'Fraccionamientos privados', icon: '🏘️' },
  { name: 'Residenciales premium', icon: '🏰' },
  { name: 'Torres mixtas', icon: '🏙️' },
  { name: 'Coto cerrado', icon: '🚧' },
  { name: 'Casa club / amenidades', icon: '🏊' },
];
---

<div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-6">
  {sectors.map((s) => (
    <div class="group flex flex-col items-center gap-3 rounded-2xl border border-white/5 bg-ink-900/40 p-6 text-center transition-all hover:border-brand-500/30 hover:bg-ink-800/60">
      <span class="text-3xl">{s.icon}</span>
      <p class="text-sm leading-tight text-white/85">{s.name}</p>
    </div>
  ))}
</div>
