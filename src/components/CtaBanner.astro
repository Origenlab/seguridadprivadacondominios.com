---
import Icon from '@/components/Icon.astro';
import { SITE } from '@/config/site';

interface Props {
  title?: string;
  subtitle?: string;
}
const {
  title = '¿Listo para elevar la seguridad de tu condominio?',
  subtitle = 'Auditoría inicial sin costo. Recibe una propuesta personalizada en menos de 48 horas.',
} = Astro.props;
---

<section class="section">
  <div class="container-pro">
    <div class="relative overflow-hidden rounded-xl bg-brand-500 p-10 md:p-14">
      <!-- Patrón decorativo -->
      <div
        class="absolute inset-0 opacity-10"
        style="background-image: linear-gradient(135deg, transparent 49%, rgba(255,255,255,0.5) 49.5%, rgba(255,255,255,0.5) 50.5%, transparent 51%); background-size: 30px 30px;"
      ></div>

      <div class="relative grid items-center gap-8 lg:grid-cols-5">
        <div class="lg:col-span-3">
          <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-widest2 text-white/85">
            <span class="h-1.5 w-1.5 rounded-full bg-white"></span>
            Cotización personalizada
          </span>
          <h2 class="mt-3 text-3xl font-bold leading-tight text-balance text-white md:text-4xl lg:text-5xl">
            {title}
          </h2>
          <p class="mt-4 max-w-2xl text-white/85">{subtitle}</p>
        </div>

        <div class="flex flex-col gap-3 lg:col-span-2 lg:items-end">
          <a href="/empresa-de-seguridad-privada-para-condominios/" class="btn bg-white text-brand-600 hover:bg-white/90 w-full lg:w-auto">
            Cotizar gratis
            <Icon name="arrow" class="h-4 w-4" />
          </a>
          <a
            href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`}
            class="btn border-2 border-white text-white hover:bg-white/10 w-full lg:w-auto"
          >
            <Icon name="phone" class="h-4 w-4" />
            {SITE.contact.phoneDisplay}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
