---
interface Stat { value: string; label: string; }
interface Props {
  items: Stat[];
  variant?: 'dark' | 'brand';
}
const { items, variant = 'dark' } = Astro.props;
---

<div
  class:list={[
    'grid gap-6 rounded-xl border p-8 md:p-10',
    variant === 'brand'
      ? 'border-brand-500/30 bg-brand-500/5'
      : 'border-white/5 bg-ink-900',
    `md:grid-cols-${items.length}`,
  ]}
>
  {items.map((s, i) => (
    <div class:list={[
      'text-center md:text-left',
      i > 0 && 'md:border-l md:border-white/10 md:pl-8',
    ]}>
      <p class="text-4xl font-bold text-brand-500 md:text-5xl">{s.value}</p>
      <p class="mt-2 text-[11px] font-semibold uppercase tracking-widest2 text-white/65">
        {s.label}
      </p>
    </div>
  ))}
</div>
