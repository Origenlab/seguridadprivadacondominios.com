---
interface Faq {
  q: string;
  a: string;
}

interface Props {
  items: readonly Faq[];
}

const { items } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
};
---

{items.length > 0 && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
