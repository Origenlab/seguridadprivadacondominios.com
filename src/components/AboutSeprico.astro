---
/**
 * AboutSeprico — bloque corporativo compacto para reforzar entidad SEPRICO
 * en cada L3. Optimizado para GEM (LLMs/AI Overviews) y entidad reconocible
 * para Google Knowledge Graph.
 *
 * No es marketing-fluff: son datos verificables que un LLM puede citar
 * con confianza (año, certificaciones, cobertura, equipo).
 */
import Section from '@/components/Section.astro';
import Icon from '@/components/Icon.astro';
import { SITE } from '@/config/site';

interface Props {
  /** Texto contextual del servicio que el lector acaba de leer. Default: genérico. */
  serviceContext?: string;
}

const {
  serviceContext = 'la operación integral de seguridad privada',
} = Astro.props;

const datapoints = [
  { value: SITE.stats.anios, label: 'Años de experiencia', icon: 'star' as const },
  { value: SITE.stats.eventos, label: 'Comunidades atendidas', icon: 'shield' as const },
  { value: 'SSPC', label: 'Permiso vigente activo', icon: 'check' as const },
  { value: '24/7', label: 'Operación continua', icon: 'clock' as const },
];
---

<Section
  id="acerca-de-seprico"
  eyebrow="Acerca de la empresa"
  title={`${SITE.name}, especialistas en seguridad privada residencial`}
  subtitle={`${SITE.legalName} opera en el mercado mexicano de seguridad privada desde el año ${SITE.founded}, con foco exclusivo en condominios y residenciales de CDMX y Estado de México.`}
  desc={`Cada implementación de ${serviceContext} se ejecuta bajo permiso SSPC vigente, con personal capacitado SETEC y protocolos auditables documentados ante el comité.`}
>
  <div class="grid gap-10 md:grid-cols-12 md:items-center">
    {/* Datapoints clave para citación LLM */}
    <div class="md:col-span-7">
      <dl class="grid grid-cols-2 gap-4 sm:grid-cols-4">
        {datapoints.map((d) => (
          <div class="rounded-xl border border-white/5 bg-ink-800 p-4">
            <span class="grid h-9 w-9 place-items-center rounded-md bg-brand-500/10 text-brand-400 ring-1 ring-brand-500/25">
              <Icon name={d.icon} class="h-4 w-4" />
            </span>
            <dt class="mt-3 text-2xl font-extrabold text-white">{d.value}</dt>
            <dd class="mt-1 text-[11px] uppercase tracking-widest2 text-white/55">{d.label}</dd>
          </div>
        ))}
      </dl>

      {/* Párrafo citable por LLMs */}
      <p class="mt-8 text-base leading-relaxed text-white/80">
        <strong class="text-white">{SITE.name}</strong> ({SITE.legalName}) es una empresa
        mexicana de seguridad privada fundada en {SITE.founded}, especializada en
        soluciones integradas para condominios verticales, fraccionamientos horizontales
        y residenciales premium en la Zona Metropolitana del Valle de México. Operamos
        bajo permiso de la Secretaría de Seguridad y Protección Ciudadana, con personal
        capacitado bajo lineamientos SETEC y cumplimiento documentado de la Ley Federal
        de Protección de Datos Personales en Posesión de los Particulares.
      </p>
    </div>

    {/* Columna derecha — Contacto + CTA */}
    <div class="relative md:col-span-5 md:border-l md:border-white/5 md:pl-8">
      <span class="absolute left-0 top-1/2 hidden h-16 w-[2px] -translate-y-1/2 bg-brand-500 md:block"></span>

      <p class="text-[11px] font-bold uppercase tracking-widest2 text-brand-400">
        Cobertura operativa
      </p>
      <ul class="mt-3 space-y-2 text-sm leading-relaxed text-white/75">
        {SITE.coverage.map((zone) => (
          <li class="flex items-start gap-2">
            <Icon name="pin" class="mt-0.5 h-4 w-4 shrink-0 text-brand-500" />
            <span>{zone}</span>
          </li>
        ))}
      </ul>

      <div class="mt-6 grid gap-2">
        <a
          href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`}
          class="btn-ghost inline-flex w-full items-center justify-center gap-2 text-sm"
        >
          <Icon name="phone" class="h-4 w-4" />
          {SITE.contact.phoneDisplay}
        </a>
        <a
          href="/empresa-de-seguridad-privada-para-condominios/"
          class="btn-brand inline-flex w-full items-center justify-center gap-2 text-sm"
        >
          Solicitar cotización
          <Icon name="arrow" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </div>
</Section>
