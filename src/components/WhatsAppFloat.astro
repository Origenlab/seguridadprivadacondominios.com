  href={href}
  target="_blank"
  rel="noopener noreferrer nofollow"
  aria-label="Contactar por WhatsApp"
  class="fixed bottom-6 right-6 z-40 grid h-14 w-14 place-items-center rounded-full bg-[#25D366] text-white shadow-[0_10px_30px_-5px_rgba(37,211,102,0.6)] transition-transform hover:scale-110"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-7 w-7">
    <path d="M19.05 4.91A10 10 0 0 0 12 2C6.5 2 2 6.48 2 12c0 1.76.46 3.45 1.34 4.95L2 22l5.27-1.31A10 10 0 0 0 12 22c5.5 0 10-4.48 10-10 0-2.67-1.05-5.18-2.95-7.09ZM12 20.27a8.27 8.27 0 0 1-4.22-1.15l-.3-.18-3.13.78.83-3.05-.2-.31A8.26 8.26 0 1 1 20.27 12c0 4.57-3.7 8.27-8.27 8.27Zm4.79-6.18c-.26-.13-1.55-.76-1.79-.85-.24-.09-.41-.13-.59.13-.18.26-.67.85-.82 1.03-.15.18-.3.2-.56.07-.26-.13-1.11-.41-2.11-1.3-.78-.7-1.31-1.56-1.46-1.82-.15-.26-.02-.4.11-.53.11-.11.26-.3.39-.45.13-.15.17-.26.26-.43.09-.17.04-.32-.02-.45-.07-.13-.59-1.43-.81-1.95-.21-.51-.43-.44-.59-.45h-.5c-.17 0-.45.07-.69.32-.24.26-.91.89-.91 2.17 0 1.28.93 2.52 1.06 2.69.13.17 1.83 2.79 4.44 3.92.62.27 1.11.43 1.49.55.63.2 1.2.17 1.65.1.5-.08 1.55-.63 1.77-1.25.22-.61.22-1.14.15-1.25-.07-.11-.24-.18-.5-.3Z"/>
  </svg>
</a>
