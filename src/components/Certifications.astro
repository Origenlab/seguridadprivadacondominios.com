---
import Icon from '@/components/Icon.astro';

const items = [
  {
    badge: 'SSPC',
    title: 'Permiso Federal SSPC',
    desc: 'Registro vigente ante la Secretaría de Seguridad y Protección Ciudadana para prestar servicios de seguridad privada.',
    icon: 'shield',
  },
  {
    badge: 'ISO',
    title: 'ISO 9001:2015',
    desc: 'Sistema de gestión de calidad certificado para procesos operativos de seguridad residencial.',
    icon: 'check',
  },
  {
    badge: 'SETEC',
    title: 'Capacitación SETEC',
    desc: 'Personal entrenado bajo lineamientos federales de capacitación en seguridad privada.',
    icon: 'patrol',
  },
  {
    badge: 'RC',
    title: 'Póliza Responsabilidad Civil',
    desc: 'Cobertura vigente que protege a residentes y administración ante cualquier incidente operativo.',
    icon: 'alert',
  },
];
---

<div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
  {items.map((c) => (
    <div class="card flex flex-col">
      <div class="flex items-center gap-3">
        <span class="grid h-12 w-12 shrink-0 place-items-center rounded-md bg-brand-500 text-white">
          <Icon name={c.icon as any} class="h-6 w-6" />
        </span>
        <span class="rounded-md border border-brand-500/30 bg-brand-500/10 px-2.5 py-1 text-[11px] font-bold uppercase tracking-widest2 text-brand-300">
          {c.badge}
        </span>
      </div>
      <h3 class="mt-5 text-base font-bold text-white">{c.title}</h3>
      <p class="mt-2 flex-1 text-sm text-white/70">{c.desc}</p>
    </div>
  ))}
</div>
