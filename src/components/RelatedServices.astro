---
/**
 * Servicios relacionados — internal linking SEO.
 * Pattern service-card aprobado (imagen + gradient + label + título overlay + body).
 * Sin animaciones (preferencia del usuario).
 */
import Section from '@/components/Section.astro';
import Icon from '@/components/Icon.astro';
import { resolveServiceMeta, getRelatedServiceSlugs } from '@/config/site';
import { getEntry } from 'astro:content';

interface Props {
  /** Slug del servicio actual (se excluye automáticamente). */
  currentSlug: string;
  /** Lista declarada en el MDX (opcional). */
  declared?: readonly string[];
  /** Número de cards a mostrar. */
  count?: number;
  /** Heading customizable. */
  heading?: string;
  /** Eyebrow customizable. */
  eyebrow?: string;
  /** Subtítulo opcional. */
  subtitle?: string;
}

const {
  currentSlug,
  declared = [],
  count = 4,
  heading = 'Servicios complementarios',
  eyebrow = 'Solución integral',
  subtitle = 'Combina servicios para fortalecer la protección integral de tu condominio.',
} = Astro.props;

const slugs = getRelatedServiceSlugs(currentSlug, declared, count);
const items = resolveServiceMeta(slugs);

// Enriquecer con description e image desde la collection
const enriched = await Promise.all(
  items.map(async (it) => {
    try {
      const entry = await getEntry('servicios', it.slug);
      return {
        ...it,
        description: entry?.data.description ?? '',
        image: entry?.data.image ?? '/images/og/og-image.webp',
      };
    } catch {
      return { ...it, description: '', image: '/images/og/og-image.webp' };
    }
  }),
);
---

{enriched.length > 0 && (
  <Section
    id="servicios-relacionados"
    eyebrow={eyebrow}
    title={heading}
    subtitle={subtitle}
    desc="Cada servicio se integra al mismo modelo operativo bajo un solo proveedor responsable."
    bg="darker"
  >
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {enriched.map((s, i) => (
        <a
          href={s.href}
          class="service-card group flex flex-col"
          title={`Conoce el servicio de ${s.title}`}
        >
          <div class="service-card-image">
            <img
              src={s.image}
              alt={s.title}
              loading="lazy"
              decoding="async"
              class="absolute inset-0 h-full w-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/70 to-ink-950/10"></div>
            <span class="absolute top-3 left-3 rounded-md bg-brand-500/95 px-2.5 py-1 text-[10px] font-extrabold uppercase tracking-widest2 text-white shadow-brand backdrop-blur-sm">
              0{i + 1}
            </span>
            <span class="absolute top-3 right-3 grid h-9 w-9 place-items-center rounded-md bg-ink-950/70 text-brand-300 backdrop-blur-sm">
              <Icon name={s.icon as any} class="h-4 w-4" />
            </span>
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <h3 class="text-lg font-bold leading-tight text-white">{s.title}</h3>
            </div>
          </div>

          <div class="service-card-body">
            {s.description && (
              <p class="flex-1 text-sm leading-relaxed text-white/70">{s.description}</p>
            )}
            <span class="mt-5 inline-flex items-center gap-2 text-xs font-semibold text-brand-500 group-hover:text-brand-400">
              Ver servicio
              <Icon name="arrow" class="h-3.5 w-3.5" />
            </span>
          </div>
        </a>
      ))}
    </div>
  </Section>
)}
