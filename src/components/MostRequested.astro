---
import Icon from '@/components/Icon.astro';

const items = [
  {
    icon: 'shield',
    title: 'Personal de Seguridad',
    desc: 'Guardias capacitados SETEC con supervisión activa, bitácora digital y rotación inteligente las 24 horas.',
    image: '/images/rrhh/personal-de-seguridad.avif',
    href: '/personal-de-seguridad/',
    badge: 'Más contratado',
  },
  {
    icon: 'cctv',
    title: 'Monitoreo Electrónico',
    desc: 'Centro de operaciones 24/7 con cámaras IP HD/4K, sensores y respuesta inmediata ante incidencias.',
    image: '/images/servicios/monitoreo-electronico.avif',
    href: '/monitoreo-electronico/',
    badge: 'Top tecnología',
  },
  {
    icon: 'access',
    title: 'Control de Acceso',
    desc: 'Plumas automáticas, lectores biométricos y registro digital de visitantes con foto e identificación.',
    image: '/images/servicios/control-de-acceso.avif',
    href: '/control-de-acceso/',
    badge: 'Más solicitado',
  },
  {
    icon: 'check',
    title: 'Consultoría en Seguridad',
    desc: 'Auditoría de riesgos sin costo, propuesta documentada en 48 horas y plan operativo a 12 meses.',
    image: '/images/servicios/consultoria-en-seguridad.avif',
    href: '/consultoria-en-seguridad/',
    badge: 'Sin costo',
  },
];
---

<div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
  {items.map((s) => (
    <a href={s.href} class="service-card group">
      <div class="service-card-image">
        <img
          src={s.image}
          alt={s.title}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-ink-950/85 via-ink-950/40 to-transparent"></div>
        <span class="absolute top-3 left-3 grid h-9 w-9 place-items-center rounded-md bg-brand-500/90 text-white backdrop-blur-sm">
          <Icon name={s.icon as any} class="h-4 w-4" />
        </span>
        <span class="absolute top-3 right-3 rounded-full border border-white/30 bg-ink-950/50 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-widest2 text-white backdrop-blur-sm">
          {s.badge}
        </span>
      </div>

      <div class="service-card-body">
        <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-widest2 text-brand-500">
          <span class="h-1 w-1 rounded-full bg-brand-500"></span>
          Servicio destacado
        </span>
        <div class="mt-2 h-[2px] w-8 bg-brand-500"></div>

        <h3 class="mt-3 text-base font-bold text-white">{s.title}</h3>
        <p class="mt-2 text-xs leading-relaxed text-white/65">{s.desc}</p>

        <span class="mt-4 inline-flex items-center gap-2 text-xs font-semibold text-brand-500 group-hover:text-brand-400">
          Conocer más
          <Icon name="arrow" class="h-3.5 w-3.5" />
        </span>
      </div>
    </a>
  ))}
</div>
